{
  "default_route": "default",
  "telemetry_db_path": "data/mok_telemetry.db",
  "guardrails": {
    "vram_soft_limit_gb": 14.0,
    "vram_hard_limit_gb": 14.5,
    "adapter_lru_limit": 3,
    "max_context_tokens": 8192,
    "eviction_policy": "lru"
  },
  "experts": [
    {
      "route": "default",
      "adapter_path": "local_adapters/default/adapter.file",
      "anchors": ["general", "chat", "question"],
      "description": "Fallback route for general requests."
    },
    {
      "route": "coding",
      "adapter_path": "local_adapters/coding/adapter.file",
      "anchors": ["python", "code", "function", "class", "bug", "test", "fastapi"],
      "description": "Coding and software-engineering expert route."
    },
    {
      "route": "architecture",
      "adapter_path": "local_adapters/architecture/adapter.file",
      "anchors": ["architecture", "kernel", "routing", "vram", "adapter", "telemetry"],
      "description": "MOK design and systems architecture route."
    }
  ]
}
